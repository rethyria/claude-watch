<?xml version="1.0" encoding="utf-8"?>
<!-- The tile carousel picker's preview (issue #28) — REQUIRED metadata, or
     the picker shows a broken placeholder card. Derived from ic_bridge_chip
     (the Halo ring glyph) on the AMOLED black, with the Running-green accent
     the healthy tile actually uses: a static brand mark, deliberately NOT a
     fake screenshot of the layout. A rendered preview would have to be
     regenerated by hand every time tileLayout changes and would silently rot
     into a lie about what the tile shows — the ring glyph is timeless and
     honest about which app this is, which is all a picker card owes. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="192dp"
    android:height="192dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Full-bleed AMOLED black, the Halo background. -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M0,0h24v24H0z" />
    <!-- The ring glyph, scaled to the middle, in Halo Running green
         (#6CB289) — the healthy accent. -->
    <group
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:pivotX="12"
        android:pivotY="12">
        <path
            android:fillColor="#FF6CB289"
            android:pathData="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2zM12,20c-4.42,0 -8,-3.58 -8,-8s3.58,-8 8,-8 8,3.58 8,8 -3.58,8 -8,8z" />
    </group>
</vector>
