<?xml version="1.0" encoding="utf-8"?>
<!--
  v1 ships cleartext HTTP on the LAN only (TLS is a separate, deferred issue).
  Cleartext is opt-in per destination — never the global cleartext flag.

  Android's network security config cannot express CIDR ranges, so the
  RFC1918-only scope is enforced in two cooperating layers:

  1. This config permits cleartext solely for the app-private hostname
     `bridge.internal` (plus the emulator host alias and loopback for
     `adb reverse` setups). Everything else keeps the platform default:
     cleartext blocked.
  2. All bridge traffic is sent to http://bridge.internal:<port>, and
     BridgeClient pins that name's DNS answer to an operator-entered IPv4
     address that PrivateHosts has validated as RFC1918 (10/8, 172.16/12,
     192.168/16) or loopback. A non-private address never gets a socket.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">bridge.internal</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
