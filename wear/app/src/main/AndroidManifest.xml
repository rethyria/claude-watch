<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Haptic feedback grammar for command acks/failures (issue #20). -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Held-Wi-Fi escalation when the BT-proxy path to the bridge is broken:
         ConnectivityManager.requestNetwork(TRANSPORT_WIFI) in WifiNetworkEscalator. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- The bridge connection's process lifetime (issue #24): a connectedDevice
         foreground service holds the SSE stream open past activity destroy and
         Doze. CHANGE_NETWORK_STATE above already satisfies the connectedDevice
         prerequisite on API 34+; CHANGE_WIFI_STATE is held alongside it for the
         same escalation surface. POST_NOTIFICATIONS because targetSdk 34: the
         FGS notification (and its OngoingActivity chip) is invisible without
         the runtime grant on API 33+ — denial is tolerated, the service still
         runs. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:icon="@android:drawable/sym_def_app_icon"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Standalone watch app: no phone relay, installs without a companion. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <uses-library
            android:name="com.google.android.wearable"
            android:required="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Started (never bound) foreground service holding the bridge
             connection open with process lifetime (issue #24). -->
        <service
            android:name=".BridgeSessionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />
    </application>
</manifest>
