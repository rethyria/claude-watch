  {
    "name": "sse: permission-request Bash",
    "event": {
      "event": "permission-request",
      "data": {
        "permissionId": "<permission-1>",
        "tool_name": "Bash",
        "session_id": "fixture-hook-session-1",
        "cwd": "/tmp/fixture-project",
        "tool_input": {
          "command": "ls -la"
        },
        "permission_suggestions": [
          {
            "type": "addRules",
            "rules": [
              {
                "toolName": "Bash",
                "ruleContent": "ls:*"
              }
            ],
            "behavior": "allow",
            "destination": "session"
          }
        ],
        "options": [
          {
            "behavior": "allow",
            "label": "Yes",
            "description": "Allow this once"
          },
          {
            "behavior": "allow-always",
            "label": "Yes, don't ask again",
            "description": "Allow and apply the suggested permission rules"
          },
          {
            "behavior": "deny",
            "label": "No",
            "description": "Deny this request"
          }
        ],
        "sessionId": "<session-1>"
      }
    }
  },
  {
    "name": "decision allow-always",
    "request": {
      "method": "POST",
      "path": "/v1/command",
      "authenticated": true,
      "body": {
        "permissionId": "<permission-1>",
        "decision": {
          "behavior": "allow-always"
        }
      }
    },
    "response": {
      "status": 200,
      "body": {
        "ok": true
      }
    }
  },
  {
    "name": "hook response: allow-always applies suggestions",
    "request": {
      "method": "POST",
      "path": "/v1/hooks/permission",
      "blocking": true
    },
    "response": {
      "status": 200,
      "body": {
        "hookSpecificOutput": {
          "hookEventName": "PermissionRequest",
          "decision": {
            "behavior": "allow",
            "updatedPermissions": [
              {
                "type": "addRules",
                "rules": [
                  {
                    "toolName": "Bash",
                    "ruleContent": "ls:*"
                  }
                ],
                "behavior": "allow",
                "destination": "session"
              }
            ]
          }
        }
      }
    }
  },
