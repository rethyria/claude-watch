  {
    "name": "pair refused below min proto",
    "request": {
      "method": "POST",
      "path": "/v1/pair",
      "authenticated": false,
      "body": {
        "code": "<pairing-code>",
        "proto": 2,
        "deviceName": "fixture-watch"
      }
    },
    "response": {
      "status": 426,
      "body": {
        "error": "Unsupported protocol version: this bridge requires proto >= 3, but the pair request declared 2. Update the watch app.",
        "proto": 3,
        "minProto": 3
      }
    }
  },
